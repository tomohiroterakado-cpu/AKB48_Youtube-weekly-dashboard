# Google Cloud deployment settings
# Copy this file to deploy/cloud-run.env and fill in your project id.

PROJECT_ID=your-google-cloud-project-id
REGION=asia-northeast1
SERVICE_NAME=akb-weekly-dashboard
REPOSITORY=akb-dashboard

# true: anyone with the URL can view the dashboard.
# false: only Google accounts/IAM users granted Cloud Run Invoker can view it.
ALLOW_UNAUTHENTICATED=true
